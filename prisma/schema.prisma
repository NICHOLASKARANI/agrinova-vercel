generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String
  password      String
  role          Role      @default(FIELD_AGENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  assignedFields Field[]  
  updates        Update[]
}

model Field {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  cropType      String
  plantingDate  DateTime
  currentStage  Stage     @default(PLANTED)
  location      String?
  size          Float?
  agentId       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  agent         User?     @relation(fields: [agentId], references: [id])
  updates       Update[]
  predictions   Prediction[]
}

model Update {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  fieldId       String    @db.ObjectId
  userId        String    @db.ObjectId
  newStage      Stage
  notes         String?
  healthScore   Int?
  createdAt     DateTime  @default(now())
  
  field         Field     @relation(fields: [fieldId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
}

model Prediction {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  fieldId       String    @db.ObjectId
  riskLevel     String
  confidence    Float
  recommendedAction String?
  predictedHarvestDate DateTime?
  createdAt     DateTime  @default(now())
  
  field         Field     @relation(fields: [fieldId], references: [id])
}

enum Role {
  ADMIN
  FIELD_AGENT
}

enum Stage {
  PLANTED
  GROWING
  READY
  HARVESTED
}
